    android:viewportHeight="108">

    <!--
        Single eighth-note (quaver) centred in the 108×108 canvas.
        Safe zone: 18–90 on each axis. The note sits comfortably inside it.

        Anatomy:
          • Notehead: filled ellipse at bottom-left, tilted slightly
          • Stem:     vertical rectangle up the right side of the notehead
          • Flag:     curved path from the top of the stem sweeping right then down
    -->

    <!-- Notehead (ellipse approximated with a circle-ish rounded rect) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M44,76
            a10,7 -20 1,0 20,0
            a10,7 -20 1,0 -20,0
            Z" />

    <!-- Stem -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M60,76
            L60,34
            L64,34
            L64,76
            Z" />

    <!-- Flag — a gentle swoop from top of stem -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M64,34
            C72,36 76,42 74,50
            C72,58 66,60 64,58
            L64,54
            C66,56 70,54 71,48
            C72,42 69,38 64,38
            Z" />

</vector>
